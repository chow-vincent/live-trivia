{
  "name": "live-trivia",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @live-trivia/shared --filter @live-trivia/server --filter @live-trivia/client dev",
    "build": "pnpm --filter @live-trivia/shared build && pnpm --parallel --filter @live-trivia/server --filter @live-trivia/client build",
    "deploy": "cd packages/infra && ./deploy.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
